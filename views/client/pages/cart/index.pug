extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
  .container.my-3
    .row
      .col-12
        +box-head("Giỏ hàng")

    .row
      .col-12
        table(class="table table-bordered")
          thead
            tr
              th STT
              th Ảnh
              th Tên
              th Giá
              th Số lượng
              th Tổng tiền
              th Hành động
          tbody
            each item, index in productInfo
              tr
                td= index + 1
                td
                  img(src=item.thumbnail style="width: 80px")
                td
                  a(href=`/products/detail/${item.slug}`)= item.title
                td
                  del= item.price + ' VNĐ'
                  |  → 
                  strong= item.pricenew + ' VNĐ'
                td
                  input(
                    type="number"
                    name="quantity"
                    value=item.quantity
                    min="1"
                    item-id=`${item._id}`
                    style="width: 60px"
                  )
                td= item.pricenew * item.quantity + ' VNĐ'
                td
                  a(
                    href=`/cart/delete/${item._id}`
                    class="btn btn-danger"
                  ) Xóa

    h3(class="text-right mt-3")
      | Tổng đơn hàng: 
      strong= productInfo.reduce((total, item) => total + item.pricenew * item.quantity, 0) + ' VNĐ'

    div(class="text-right mt-3")
      a(href="/checkout" class="btn btn-success") THANH TOÁN