extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-3
    .row
      .col-12
        +box-head("Danh sách phòng")

    .row.mb-3
      .col-12
        a(
          href="/rooms-chat/create"
          class="btn btn-sm btn-success mr-1"
        ) Tạo phòng chat

    .row
    //-   each room in rooms
        .col-6
          div(class="box-room")
            div(class="inner-avatar")
              img(
                src=room.avatar || "https://robohash.org/" + room._id + ".png"
                alt=room.name
              )
            div(class="inner-info")
              div(class="inner-name") #{room.name}
              div(class="inner-buttons")
                a(
                  href="/rooms-chat/" + room._id
                  class="btn btn-sm btn-primary mr-1"
                ) Nhắn tin