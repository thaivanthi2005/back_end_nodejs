extends ../../layouts/auth.pug

include ../../mixins/alert.pug

block main
  +alert(success, error)

  .container.my-5
    .row.justify-content-center
      .col-md-6.col-lg-5
        .card.shadow
          .card-body
            h3.text-center.mb-4 Đăng nhập

            form(
              action=`${prefixAdmin}/auth/login`
              method="POST"
            )

              // Email
              .form-group.mb-3
                label(for="email") Email
                input.form-control(
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Nhập email"
                  required
                )

              // Password
              .form-group.mb-3
                label(for="password") Mật khẩu
                input.form-control(
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Nhập mật khẩu"
                  required
                )

              // Remember me
              .form-check.mb-3
                input.form-check-input(
                  type="checkbox"
                  id="remember"
                  name="remember"
                )
                label.form-check-label(for="remember") Nhớ đăng nhập

              // Submit button
              button.btn.btn-primary.w-100(type="submit")
                | Đăng nhập

              // Forgot password
              .text-center.mt-3
                a(href=`${prefixAdmin}/auth/forgot-password`) Quên mật khẩu?