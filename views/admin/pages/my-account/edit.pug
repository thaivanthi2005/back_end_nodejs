extends ../../layouts/default.pug

block main
    h1 Cập nhật thông tin cá nhân

    form(
        action=`/${prefixAdmin}/my-account/edit?_method=PATCH`
        method="POST"
        enctype="multipart/form-data"
    )
        div(class="form-group")
            label(for="fullName") Họ tên *
            input(
                type="text"
                class="form-control"
                id="fullName"
                name="fullName"
                required
                value=user.fullName
            )

        div(class="form-group")
            label(for="email") Email *
            input(
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
                value=user.email
            )

        div(class="form-group")
            label(for="password") Mật khẩu
            input(
                type="password"
                class="form-control"
                id="password"
                name="password"
            )

        div(class="form-group")
            label(for="phone") Số điện thoại
            input(
                type="text"
                class="form-control"
                id="phone"
                name="phone"
                value=user.phone
            )

        div(class="form-group" upload-image)
            label(for="avatar") Avatar

            input.form-control-file(
                type="file"
                id="avatar"
                name="avatar"
                accept="image/*"
                upload-image-input
            )

            if (user.avatar)
                img(
                    src=user.avatar
                    alt="Preview"
                    width="200"
                    class="mt-3 mb-3 d-block"
                    upload-image-preview
                )

                button.btn.btn-secondary(
                    type="button"
                    upload-image-delete
                ) Xóa ảnh

        button(
            type="submit"
            class="btn btn-primary"
        ) Cập nhật