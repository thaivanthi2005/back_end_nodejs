extends ../../layouts/default.pug
include ../../mixins/category-tree.pug

block main
  h1(class="mb-4") Phân quyền

  if(roles)
    div(class="text-right")
      button(
        type="submit"
        class="btn btn-primary mb-3 button-submit"
      ) Cập nhật

    table(
      class="table table-hover table-sm"
    )
      thead
        tr
          th Tính năng
          each item in roles 
            th(class="text-center") #{item.title}
      tbody
        tr
          td(colspan="4")
            b Danh mục sản phẩm

        tr(data-name="products-category_view")
          td Xem
          each item in roles
            td(class="text-center")
              input(type="checkbox")

        tr(data-name="products-category_create")
          td Thêm mới
          each item in roles
            td(class="text-center")
              input(type="checkbox")

        tr(data-name="products-category_edit")
          td Chỉnh sửa
          each item in roles
            td(class="text-center")
              input(type="checkbox")

        tr(data-name="products-category_delete")
          td Xóa
          each item in roles
            td(class="text-center")
              input(type="checkbox")
